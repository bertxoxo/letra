generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Letter {
  id             String      @id @default(uuid())
  slug           String      @unique
  title          String
  message        String
  category       String
  spotifyTrackId String?     @map("spotify_track_id")
  songName       String?     @map("song_name")
  artistName     String?     @map("artist_name")
  albumName      String?     @map("album_name")
  albumCover     String?     @map("album_cover")
  spotifyUrl     String?     @map("spotify_url")
  senderName     String?     @map("sender_name")
  senderEmail    String      @map("sender_email")
  recipientName  String      @map("recipient_name")
  recipientEmail String?     @map("recipient_email")
  visibility     Visibility  @default(PUBLIC)
  publishType    PublishType @map("publish_type")
  views          Int         @default(0)
  reactions      Int         @default(0)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  firstViewedAt  DateTime?   @map("first_viewed_at")
  replies        Reply[]
  anonymousId    String?     @map("anonymous_id")
  

  @@index([category])
  @@index([visibility])
  @@index([createdAt])
  @@map("letters")
  
}

model Reply {
  id             String          @id @default(uuid())
  letterId       String          @map("letter_id")
  message        String
  spotifyTrackId String?         @map("spotify_track_id")
  songName       String?         @map("song_name")
  artistName     String?         @map("artist_name")
  albumCover     String?         @map("album_cover")
  spotifyUrl     String?         @map("spotify_url")
  createdAt      DateTime        @default(now()) @map("created_at")
  authorRole     ReplyAuthorRole @map("author_role")
  letter         Letter          @relation(fields: [letterId], references: [id], onDelete: Cascade)

  @@index([letterId])
  @@map("replies")
}

model MagicLink {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  @@index([token])
  @@map("magic_links")
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum PublishType {
  PUBLISH_ONLY
  EMAIL_ONLY
  PUBLISH_AND_EMAIL
}

enum ReplyAuthorRole {
  SENDER
  RECIPIENT
}
