# --- Database ---
# Supabase free tier: https://supabase.com -> New project -> Settings -> Database -> Connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Email (Resend) ---
# https://resend.com -> API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="sendthesong <noreply@yourdomain.com>"

# --- Spotify (client credentials, search only, no user login) ---
# https://developer.spotify.com/dashboard -> Create app
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# --- Auth ---
# Any long random string, e.g. `openssl rand -hex 32`
AUTH_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
